NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_TOKEN_ADDRESS=
NEXT_PUBLIC_FUSE_CHAIN_ID=122
NEXT_PUBLIC_FUSESCAN_URL=https://explorer.fuse.io

# Demo mode: set to "true" for Vercel deployment without backend
# When true, all API calls return mock data and a demo banner is shown
NEXT_PUBLIC_DEMO_MODE=false

# ── Wallet Connect ──────────────────────────────────
# Get project ID from: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Chain Configuration ─────────────────────────────
# Set to "mainnet" for Fuse Mainnet (chain 122)
# Set to "testnet" for Fuse Spark (chain 123)
NEXT_PUBLIC_CHAIN=testnet

