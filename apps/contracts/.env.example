# Deployer wallet private key (with 0x prefix)
DEPLOYER_PRIVATE_KEY=0xyour-private-key-here

# Fuse RPC endpoints (defaults used if empty)
FUSE_RPC_URL=https://rpc.fuse.io
FUSE_SPARK_RPC_URL=https://rpc.fusespark.io

# Fuse Explorer API key (for contract verification on FuseScan)
FUSE_EXPLORER_API_KEY=

# ERC-4337 EntryPoint address (canonical v0.6 default if empty)
ENTRYPOINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789

# Gas reporting (set to "true" to enable)
REPORT_GAS=false

# Fork Fuse mainnet for local testing (set to "true" to enable)
FORK_FUSE=
