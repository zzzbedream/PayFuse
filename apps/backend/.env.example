# Server
NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/payfuse

# JWT (IMPORTANT: Generate a strong random secret for production)
# Use: openssl rand -base64 32
JWT_SECRET=<GENERATE_RANDOM_STRING_MIN_32_CHARS>
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# ── Fuse Network ────────────────────────────────────
FUSE_RPC_URL=https://rpc.fuse.io
FUSE_CHAIN_ID=122

# ── Smart Contract Addresses (set after deploying) ──
PAYMENT_CONTRACT_ADDRESS=
TOKEN_CONTRACT_ADDRESS=
FORWARDER_CONTRACT_ADDRESS=
PAYMASTER_CONTRACT_ADDRESS=

# ── Relayer (backend wallet that pays gas for users) ─
# This wallet needs FUSE balance to sponsor gas
# SECURITY: Only the relayer key should be here, NOT merchant keys
RELAYER_PRIVATE_KEY=

# ── FuseScan API ────────────────────────────────────
FUSESCAN_API_URL=https://explorer.fuse.io/api
FUSESCAN_API_KEY=

# ── SII (Chilean Tax Service — RUT validation) ──────
SII_API_URL=https://api.libredte.cl/api
SII_API_KEY=

# ── ERC-4337 EntryPoint ────────────────────────────
ENTRYPOINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789

# ── Buda.com Integration ────────────────────────────
# Get API credentials from: https://www.buda.com/api_keys
BUDA_API_URL=https://www.buda.com/api/v2
BUDA_API_KEY=
BUDA_API_SECRET=
BUDA_REFERRAL_CODE=PAYFUSE
BUDA_WEBHOOK_SECRET=
